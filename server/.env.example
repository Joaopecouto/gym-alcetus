# --- Auth ---
# Google OAuth Client ID (do app que voce ja tem no Google Cloud Console)
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com

# Segredo pra assinar JWT de sessao. Gere com:
#   openssl rand -base64 48
JWT_SECRET=troque-esse-valor-em-producao

# --- Cookies ---
# Em producao com HTTPS deixe true (default). Em dev local sem HTTPS, false.
COOKIE_SECURE=true
# Opcional. Util se voce hospedar API e front em subdominios diferentes.
# COOKIE_DOMAIN=.seudominio.com

# --- Servidor ---
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# --- Caminhos (opcionais — defaults batem com o layout do repo) ---
# DB_PATH=/app/data/iron-track.db
# STATIC_DIR=/app/dist
