    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.38.2",
    "fastify": "^5.2.0",
    "google-auth-library": "^9.15.0",
    "jose": "^5.9.6",
    "nanoid": "^5.0.9",
    "pino-pretty": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "~6.0.2"
